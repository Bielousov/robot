#
# Google VoiceHAT I2S Configuration - 16kHz Mono
# Optimized for Vosk speech recognition
#

# Hardware reference - Google VoiceHAT SoundCard
pcm.dmic_hw {
    type hw
    card 0
    device 0
    channels 1
    rate 16000
    format S16_LE
}

# Microphone with software volume boost
pcm.dmic_sv {
    type softvol
    slave.pcm dmic_hw
    control {
        name "Mic Boost"
        card 0
    }
    min_dB -3.0
    max_dB 36.0
}

# Speaker amplifier - mono
pcm.speaker_hw {
    type hw
    card 0
    device 0
    channels 1
    rate 16000
    format S16_LE
}